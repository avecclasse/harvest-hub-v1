# InstantDB App ID is hardcoded in src/lib/db.ts
# Copy to .env.local and fill in values.

# Comma-separated admin emails (case-insensitive).
# Used for UI gating AND baked into InstantDB permissions when you push perms.
# After changing this list, re-run: npx instant-cli@latest push perms
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com
